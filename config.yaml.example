mode: paper
heartbeat_interval_seconds: 60
claude_timeout_seconds: 120

market_hours:
  open: "09:30"
  close: "16:00"
  early_close: "13:00"
  tz: "America/New_York"

watchlist:
  - AAPL
  - SPY
  - TSLA

history:
  interval: "1m"
  lookback_hours: 6.5

options:
  nearest_expiries: 2

safety:
  max_position_size_pct: 5.0
  daily_loss_threshold_pct: 5.0
  max_consecutive_agent_failures: 3
